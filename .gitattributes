# --- Git LFS for Binary Assets ---
# KiCad 9 Binaries & Libraries
*.kicad_pcb filter=lfs diff=lfs merge=lfs -text
*.kicad_sch filter=lfs diff=lfs merge=lfs -text
*.kicad_mod filter=lfs diff=lfs merge=lfs -text
*.kicad_sym filter=lfs diff=lfs merge=lfs -text
*.kicad_wks filter=lfs diff=lfs merge=lfs -text
*.kicad_dru filter=lfs diff=lfs merge=lfs -text
*.pretty/** filter=lfs diff=lfs merge=lfs -text
*.3dshapes/** filter=lfs diff=lfs merge=lfs -text
# --- Legacy Support (Optional) ---
*.lib filter=lfs diff=lfs merge=lfs -text
*.pretty filter=lfs diff=lfs merge=lfs -text

# Mechanical / Onshape Exports (src/Mechanical/)
*.step filter=lfs diff=lfs merge=lfs -text
*.stp filter=lfs diff=lfs merge=lfs -text
*.stl filter=lfs diff=lfs merge=lfs -text
*.iges filter=lfs diff=lfs merge=lfs -text
*.igs filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text
# --- Line Ending Protection (Binary / No-Touch) ---
# Ensure these files are never modified by git's auto-crlf
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.zip binary
*.tar.gz binary
# --- Text Handling for Docs & Source ---
# Force LF (Linux-style) for cross-platform consistency
*.md text eol=lf
*.txt text eol=lf
*.cs text eol=lf
*.json text eol=lf
*.patch text eol=lf
*.gitignore text eol=lf
/LICENSE text eol=lf
